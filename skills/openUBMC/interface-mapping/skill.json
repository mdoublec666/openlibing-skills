{
  "name": "openubmc-interface-mapping",
  "version": "1.0.0",
  "description": "开发 openUBMC 北向接口映射配置（Redfish / Web-backend / CLI / SNMP），涵盖 rackmount 仓库的 mapping_config JSON 编写、Schema 文件配置、ProcessingFlow 资源协作接口映射、Statements 数据处理和 ReqBody/RspBody 配置。",
  "author": "OpenUBMC Team",
  "license": "MulanPSL-2.0",
  "openubmc": {
    "minVersion": "1.0.0",
    "maxVersion": "2.0.0",
    "components": ["redfish", "web-backend", "cli", "snmp", "mdb", "mdb_interface", "rackmount"]
  },
  "dependencies": {
    "bingo-cli": ">=1.0.0",
    "mdb_interface": ">=1.0.0",
    "rackmount": ">=1.0.0"
  },
  "files": [
    "SKILL.md",
    "skill.json"
  ],
  "keywords": [
    "redfish",
    "interface-mapping",
    "mapping-config",
    "rackmount",
    "web-backend",
    "cli",
    "snmp",
    "schema",
    "processing-flow",
    "statements",
    "reqbody",
    "rspbody",
    "odata",
    "openubmc"
  ],
  "categories": [
    "development",
    "interface",
    "redfish"
  ],
  "usage": {
    "prompts": [
      "新增Redfish接口映射配置",
      "编写mapping_config JSON",
      "配置ProcessingFlow资源协作接口映射",
      "编写ReqBody请求体校验",
      "配置RspBody响应体",
      "创建Redfish Schema文件",
      "Statements数据处理转换",
      "CallIf条件执行和Foreach循环"
    ]
  }
}
